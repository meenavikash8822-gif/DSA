#include <iostream>
using namespace std;

int main(){
    int arr[5];
    int sum = 0;
    cout<<"enter 5 numbers"<<"\n";
    for(int i = 0; i<5; i++){
        cin>>arr[i];
        sum = sum + arr[i];
    }
    cout<<"sum of array elements are.."<<"\n";
    for (int i = 0; i<5; i++){
        cout<<arr[i]<<" ";
        
    }
    cout<<"sum of array element are..."<<sum;
}


